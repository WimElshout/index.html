<!doctype html>
<html lang="nl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Vraag 3</title>
  <style>
    body {
      font-family: system-ui, Segoe UI, Roboto, Arial, sans-serif;
      margin: 24px;
      max-width: 900px;
      background: #f7f9fc;
      color: #222;
    }

    h1 {
      color: #1a2a4a;
    }

    input {
      padding: 10px;
      font-size: 16px;
      width: 260px;
      border: 1px solid #ccc;
      border-radius: 8px;
    }

    button {
      padding: 10px 14px;
      font-size: 16px;
      margin-left: 8px;
      cursor: pointer;
      border: none;
      border-radius: 8px;
      background: #0078d4;
      color: white;
    }

    button:hover {
      background: #005ea2;
    }

    #f {
      margin-top: 12px;
      font-weight: 600;
      color: #b00020;
    }

    .card {
      background: white;
      padding: 24px;
      border-radius: 14px;
      box-shadow: 0 4px 18px rgba(0,0,0,0.08);
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>Vraag 3</h1>

    <p>
      Een Waals liedje van <strong>Arno</strong>.
      Heel mooi. Gaat over de liefde voor zijn moeder.
      <br><br>
      Helaas heeft dit liedje geen lyrics op Spotify. Maar als je goed zoekt kun je het antwoord elders vinden.
      <br><br>
      <strong>Onder welk lichaamsdeel van zijn moeder vindt Arno het lekker ruiken?</strong>
    </p>

    <img src="Arno.jpeg" alt="Vraag 3 afbeelding" style="width:100%; border-radius:12px;">

    <br><br>

    <input id="a" placeholder="Jouw antwoord" autocomplete="off">
    <button onclick="check()">Controleer</button>

    <p id="f"></p>
  </div>

  <script>
    function check() {
      const v = document.getElementById('a').value
        .toLowerCase()
        .trim()
        .replace(/[^a-zà-ÿ]/g, "");

      const goedeAntwoorden = ["hals", "nek"];

      if (goedeAntwoorden.includes(v)) {
        document.body.innerHTML = `
          <div style="font-family:system-ui,Segoe UI,Roboto,Arial,sans-serif; margin:24px; max-width:800px;">
            <div style="background:white; padding:24px; border-radius:14px; box-shadow:0 4px 18px rgba(0,0,0,0.08);">
              <h2 style="color:#0a7a2f;">Gefeliciteerd! 🎉</h2>
              <p>Jullie hebben alle vragen goed opgelost!</p>
            </div>
          </div>
        `;
      } else {
        document.getElementById('f').textContent = "Nog niet goed, probeer opnieuw.";
      }
    }
  </script>
</body>
</html>
